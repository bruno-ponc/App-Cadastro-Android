<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="br.com.seuprojeto.cadastroapp">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.CadastroApp">

        <!-- Tela Sobre (não exportada, só acessível internamente) -->
        <activity
            android:name=".SobreActivity"
            android:label="@string/sobre_title"
            android:exported="false"/>

        <!-- Tela Resultado (não exportada, só acessível internamente) -->
        <activity
            android:name=".ResultadoActivity"
            android:label="@string/resultado_title"
            android:exported="false"/>

        <!-- Tela Principal (exportada, pois tem intent-filter MAIN/LAUNCHER) -->
        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

    </application>


</manifest>

